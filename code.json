 {
  "title": "Gender Split of Participants by Age Group",
  "width": 260,
  "height": 260,

  "params": [
    {
      "name": "ageStep",
      "value": 0,
      "bind": {
        "input": "range",
        "min": 0,
        "max": 6,
        "step": 1,
        "name": "Age Group: "
      }
    }
  ],

  "data": {
    "values": [
      {"AgeIndex":0,"Age":"15–24","Gender":"Male","Amount":580},
      {"AgeIndex":0,"Age":"15–24","Gender":"Female","Amount":540},

      {"AgeIndex":1,"Age":"25–34","Gender":"Male","Amount":775},
      {"AgeIndex":1,"Age":"25–34","Gender":"Female","Amount":765},

      {"AgeIndex":2,"Age":"35–44","Gender":"Male","Amount":703},
      {"AgeIndex":2,"Age":"35–44","Gender":"Female","Amount":717},

      {"AgeIndex":3,"Age":"45–54","Gender":"Male","Amount":655},
      {"AgeIndex":3,"Age":"45–54","Gender":"Female","Amount":680},

      {"AgeIndex":4,"Age":"55–64","Gender":"Male","Amount":515},
      {"AgeIndex":4,"Age":"55–64","Gender":"Female","Amount":565},

      {"AgeIndex":5,"Age":"65+","Gender":"Male","Amount":420},
      {"AgeIndex":5,"Age":"65+","Gender":"Female","Amount":503},

      {"AgeIndex":6,"Age":"All Ages","Gender":"Male","Amount":3648},
      {"AgeIndex":6,"Age":"All Ages","Gender":"Female","Amount":3770}
    ]
  },

"transform": [
    {
      "filter": "datum.AgeIndex == ageStep"
    },
    {
      "joinaggregate": [
        {
          "op": "sum",
          "field": "Amount",
          "as": "TotalAmount"
        }
      ]
    },
    {
      "calculate": "datum.Amount / datum.TotalAmount",
      "as": "Percent"
    }
  ],

  "layer": [
    {
      "mark": {
        "type": "arc",
        "innerRadius": 50,
        "outerRadius": 70,
        "stroke": "#ffffff",
        "strokeWidth": 2
      },
      "encoding": {
        "theta": {
          "field": "Amount",
          "type": "quantitative"
        },
        "color": {
          "field": "Gender",
          "type": "nominal",
          "scale": {
            "domain": ["Male", "Female"],
            "range": ["#60a5fa", "#fb7185"]
          },
          "legend": {
            "orient": "bottom"
          }
        },
        "tooltip": [
          {"field":"Age"},
          {"field":"Gender"},
          {"field":"Amount","title":"Participants (000s)"},
          {"field": "Percent", "title": "Share", "format": ".1%"}
        ]
      }
    },

    {
      "mark": {
        "type": "text",
        "fontSize": 22,
        "fontWeight": "bold",
        "color": "#f8fafc",
        "align": "center",
        "baseline": "middle"
      },
      "encoding": {
        "text": {"field": "Age"}
      }
    }
  ],

  "view": {
    "stroke": null
  }
}
